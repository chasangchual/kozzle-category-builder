# Supabase Configuration
# Get these from your Supabase project settings:
# https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api

# Required: Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Required: Your Supabase anon/service role key
# Use anon key for client-side access (limited permissions)
# Use service_role key for admin access (full permissions - keep secret!)
SUPABASE_KEY=your-anon-or-service-role-key-here

# Optional: MCP (Model Context Protocol) Integration
# Set to 'true' to enable MCP server connection (default: true)
# Set to 'false' to disable MCP and use direct Supabase connection
# Useful when experiencing MCP connection errors
# USE_MCP=true

# Ollama Configuration
# Ollama server URL (default: http://localhost:11434)
OLLAMA_HOST=http://localhost:11434

# Ollama model for embeddings (default: exaone3.5:7.8b)
OLLAMA_MODEL=exaone3.5:7.8b

# Korean Word Grouper Configuration
# Database table and column names
WORD_TABLE=kor_word
LEMMA_COLUMN=lemma
DEFINITION_COLUMN=definition
PUBLIC_ID_COLUMN=public_id
LEVEL_COLUMN=level

# Clustering Configuration
# Minimum cluster size (adjust to get ~100 clusters)
MIN_CLUSTER_SIZE=10

# Supabase Connection Pool Configuration
# Maximum connections in pool (default: 10)
SUPABASE_MAX_CONNECTIONS=10

# Maximum keep-alive connections (default: 5)
SUPABASE_MAX_KEEPALIVE=5

# Idle timeout in seconds (100ms = 0.1s for aggressive cleanup)
SUPABASE_IDLE_TIMEOUT=0.1

# Connection timeout in seconds (default: 5.0)
SUPABASE_CONNECT_TIMEOUT=5.0

# Read timeout in seconds (default: 30.0)
SUPABASE_READ_TIMEOUT=30.0

# Write timeout in seconds (default: 30.0)
SUPABASE_WRITE_TIMEOUT=30.0

# Pool wait timeout in seconds (default: 10.0)
SUPABASE_POOL_TIMEOUT=10.0

# Supabase Retry Configuration
# Maximum retry attempts for transient failures (default: 3)
SUPABASE_MAX_RETRIES=3

# Initial retry delay in seconds (default: 1.0)
SUPABASE_RETRY_DELAY=1.0

# Maximum retry delay in seconds (default: 10.0)
SUPABASE_RETRY_MAX_DELAY=10.0